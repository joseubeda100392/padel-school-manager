{
  "expo": {
    "name": "Padel School",
    "slug": "padel-school-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "padelschool",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.padelschool.manager",
      "infoPlist": {
        "NSCameraUsageDescription": "Usamos la cámara para actualizar tu foto de perfil.",
        "NSPhotoLibraryUsageDescription": "Accedemos a tus fotos para actualizar tu perfil."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.padelschool.manager",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.padelschool.manager",
          "enableGooglePay": true
        }
      ],
      "expo-secure-store"
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "12deb875-4ef1-49e3-aef8-2855bee8da99"
      }
    },
    "owner": "joseubeda"
  }
}
