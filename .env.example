# ─────────────────────────────────────────────
# SUPABASE
# ─────────────────────────────────────────────
# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave anónima (segura para exponer en cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave de servicio (SOLO servidor — nunca en cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# BASE DE DATOS (Prisma)
# ─────────────────────────────────────────────
# Cadena de conexión a PostgreSQL de Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
# Para Prisma con connection pooling (producción)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────────
# Clave publicable (segura para exponer en cliente)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Clave secreta (SOLO servidor)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Secreto del webhook (para verificar eventos de Stripe)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Precio ID de la suscripción mensual en Stripe Dashboard
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx

# Precio de clase suelta en céntimos (ej: 1500 = 15€)
STRIPE_PAY_PER_CLASS_AMOUNT=1500

# ─────────────────────────────────────────────
# RAILWAY (Deploy)
# ─────────────────────────────────────────────
RAILWAY_TOKEN=your-railway-token
RAILWAY_PROJECT_ID=your-project-id

# ─────────────────────────────────────────────
# EXPO / MOBILE
# ─────────────────────────────────────────────
# Token de acceso a Expo EAS
EXPO_TOKEN=your-expo-token

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
# URL base del panel admin (para links en emails/notificaciones)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
